{
  "name": "voxout",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Provider gateway for speech synthesis, sound effects, and ASR.",
  "main": "./dist/server.js",
  "scripts": {
    "build": "npm run build:server && npm run build:web",
    "build:server": "prisma generate && tsc -p tsconfig.json",
    "build:web": "vite build --config frontend/vite.config.js",
    "test": "npm run build && node --test tests/*.test.mjs",
    "start": "node dist/server.js",
    "dev": "vite --config frontend/vite.config.js --host 0.0.0.0",
    "dev:server": "tsc -w -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "node-edge-tts": "^1.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
