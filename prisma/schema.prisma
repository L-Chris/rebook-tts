generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model ProviderConfig {
  id         String   @id @default(cuid())
  providerId String   @unique
  enabled    Boolean  @default(true)
  config     Json?
  secrets    Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([enabled])
}

model Voice {
  id              String   @id @default(cuid())
  voiceId         String   @unique
  name            String
  description     String?  @db.Text
  language        String?
  previewMimeType String?
  previewAudio    String?  @db.LongText
  metadata        Json?
  providerLinks   VoiceProviderLink[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model VoiceProviderLink {
  id                String   @id @default(cuid())
  voiceRecordId     String
  voice             Voice    @relation(fields: [voiceRecordId], references: [id], onDelete: Cascade)
  providerId        String
  providerAccountId String   @default("default")
  providerVoiceId   String?
  providerVoiceKey  String
  previewMimeType   String?
  previewAudio      String?  @db.LongText
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([providerId])
  @@index([voiceRecordId])
  @@unique([voiceRecordId, providerId, providerAccountId])
  @@unique([providerId, providerAccountId, providerVoiceKey])
}
